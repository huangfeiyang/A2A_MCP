# OpenAI
OPENAI_API_KEY=your_openai_api_key
# Official OpenAI: leave OPENAI_BASE_URL unset / commented out.
# If you previously used a third-party compatible gateway, comment it out again when
# switching back to official OpenAI API.
#
# ChatAnywhere (China mainland):
# OPENAI_BASE_URL=https://api.chatanywhere.tech/v1
#
# ChatAnywhere (outside mainland China):
# OPENAI_BASE_URL=https://api.chatanywhere.org/v1
A2A_MCP_OPENAI_MODEL=gpt-4o-mini
A2A_MCP_OPENAI_TEMPERATURE=0.2
A2A_MCP_OPENAI_TIMEOUT_S=20
A2A_MCP_MAX_TOOL_CALLS=3
A2A_MCP_TOOL_ARG_RETRY_LIMIT=1

# External APIs
OPENWEATHER_API_KEY=your_openweather_api_key
AMAP_API_KEY=your_amap_api_key

# Agent server
A2A_MCP_AGENT_HOST=0.0.0.0
A2A_MCP_AGENT_PORT=7002
A2A_MCP_AGENT_TITLE=A2A Agent Server
A2A_MCP_AGENT_NAME=autocity-agent
A2A_MCP_AGENT_VERSION=0.1.0
A2A_MCP_AGENT_DESCRIPTION=Single agent demo with MCP tool server.
A2A_MCP_AGENT_BASE_URL=http://localhost:7002
A2A_MCP_AGENT_REQUEST_TIMEOUT_S=10
A2A_MCP_MCP_BASE_URL=http://localhost:7001
A2A_MCP_MOCK_LLM=false
A2A_MCP_TRACE_ENABLED=true
A2A_MCP_TRACE_DIR=traces

# Tool server
A2A_MCP_TOOL_HOST=0.0.0.0
A2A_MCP_TOOL_PORT=7001
A2A_MCP_TOOL_TITLE=A2A MCP Tool Server
A2A_MCP_TOOL_VERSION=0.1.0
A2A_MCP_TOOL_REQUEST_TIMEOUT_S=8
A2A_MCP_TOOL_DEFAULT_TIMEZONE=Asia/Shanghai
A2A_MCP_TOOL_DEFAULT_LANG=zh_cn

# Runtime
A2A_MCP_RELOAD=false
A2A_MCP_CLIENT_TIMEOUT_S=60
